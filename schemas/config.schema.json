{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Draft Paze UCP handler configuration",
  "description": "Experimental merchant-published configuration for a Paze JavaScript SDK payment handler.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "environment",
    "client_id",
    "action_url",
    "supported_currencies",
    "supported_intents"
  ],
  "properties": {
    "environment": {
      "type": "string",
      "enum": ["sandbox", "production"]
    },
    "client_id": {
      "type": "string",
      "minLength": 1,
      "description": "Public Paze JavaScript SDK merchant client identifier."
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "action_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://",
      "description": "Merchant-hosted consumer action page that loads the Paze JavaScript SDK."
    },
    "supported_currencies": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z]{3}$"
      }
    },
    "supported_intents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["REVIEW_AND_PAY", "EXPRESS_CHECKOUT"]
      }
    },
    "accepted_card_networks": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["VISA", "MASTERCARD", "DISCOVER"]
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jknarr/paze-ucp-payment-handler/v2026-07-11/schemas/2026-07-11/types/business_config.json",
  "title": "Paze Business Config",
  "description": "Public Paze configuration advertised by a UCP business.",
  "type": "object",
  "required": ["environment", "client_id"],
  "properties": {
    "environment": {
      "type": "string",
      "enum": ["sandbox", "production"]
    },
    "client_id": {
      "type": "string",
      "minLength": 1,
      "description": "Public Paze business identity assigned during onboarding."
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "client_name": {
      "type": "string",
      "minLength": 1
    },
    "module_url": {
      "type": "string",
      "format": "uri",
      "description": "Business-selected browser module for its own consumer-facing surfaces. Platforms may apply their own module allowlist."
    },
    "supported_currencies": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z]{3}$"
      }
    },
    "supported_intents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["REVIEW_AND_PAY", "EXPRESS_CHECKOUT"]
      }
    },
    "accepted_card_networks": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["VISA", "MASTERCARD", "DISCOVER"]
      }
    }
  },
  "additionalProperties": false
}
